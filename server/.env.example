# =============================================================================
# LOCAL DEVELOPMENT — copy to server/.env
# =============================================================================

DATABASE_URL="postgresql://postgres:12345@localhost:5433/crafvia?schema=public"
PORT=3001
CORS_ORIGIN="http://localhost:5173"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

STRIPE_CHECKOUT_URL=""
DONATE_URL="https://buymeacoffee.com/crafvia"

FREE_DAILY_JOBS=50
PRO_DAILY_JOBS=1000
FREE_MAX_FILE_MB=20
PRO_MAX_FILE_MB=100

AI_PROVIDER=groq
AI_DEV_FALLBACK=true
AI_ALLOW_FREE_ACCESS=true

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=dall-e-3

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_API_KEY=

HUGGINGFACE_API_KEY=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_PROVIDER=auto

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Admin panel — comma-separated emails promoted to admin on login/seed
ADMIN_EMAILS=you@example.com

# Optional — creates/resets admin account when running npm run db:seed
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# =============================================================================
